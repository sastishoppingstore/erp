{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ERP System",
  "version": "0.1.0",
  "identifier": "com.erp.system",
  "build": {
    "frontendDist": "http://test.mzbloodbridge.pk/",
    "devUrl": "http://test.mzbloodbridge.pk/",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "ERP System",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
